	<!-- ============================================================
	     SUSTAIN  (no cue -> pull path; vanillaLogic + tense)
	     The four battle CUES above are the "hit": pushed instantly by
	     IncidentWorker and scaled to raid points, decaying Legendary ->
	     Large -> Medium -> Small. But once a cued track ends and danger
	     is still High, ChooseNextSong falls back to the pull path, and
	     without any tense=true track there, it finds nothing, logs
	     "Couldn't find a track to play" and force-enables the Vanilla
	     theme. These duplicate defs point at the same clips (ContentFinder
	     caches by path, so nothing loads twice) and fill that hole.
	     ============================================================ -->

	<MusicExpanded.TrackDef>
		<label>Arcanum - Battle at Vendigroth</label>
		<defName>ME_Arcanum_Sustain_BattleAtVendigroth</defName>
		<clipPath>MusicExpanded/Arcanum/Arcanum- Battle At Vendigroth</clipPath>
		<vanillaLogic>true</vanillaLogic>
		<tense>true</tense>
	</MusicExpanded.TrackDef>

